<icecast>
    <location>Brasil</location>
    <admin>admin@painelstream.com</admin>
    <hostname>14.stmip.net</hostname>

    <limits>
        <clients>5000</clients>
        <sources>200</sources>
        <queue-size>524288</queue-size>
        <client-timeout>30</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>10</source-timeout>
        <burst-on-connect>1</burst-on-connect>
        <burst-size>65535</burst-size>
    </limits>

    <authentication>
        <source-password>SENHA_SOURCEgs67dg67gdas</source-password>
        <relay-password>SENHA_RELAYhdaskjdhah788787</relay-password>
        <admin-user>admin</admin-user>
        <admin-password>SENHA_ADMINndasndas78d9</admin-password>
    </authentication>

    <listen-socket>
        <port>8000</port>
    </listen-socket>

    <fileserve>1</fileserve>

    <mime-types>
        <mime-type>
            <type>audio/ogg</type>
            <extension>ogg</extension>
        </mime-type>
        <mime-type>
            <type>audio/opus</type>
            <extension>opus</extension>
        </mime-type>
    </mime-types>

    <paths>
        <basedir>/usr/share/icecast2</basedir>
        <logdir>/var/log/icecast2</logdir>
        <webroot>/usr/share/icecast2/web</webroot>
        <adminroot>/usr/share/icecast2/admin</adminroot>
    </paths>

    <security>
        <chroot>0</chroot>
    </security>
</icecast>