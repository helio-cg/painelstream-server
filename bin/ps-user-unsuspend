#!/bin/bash
set -e

USERNAME="$1"
PASS="$2"
LISTENERS="$3"

# Includes
source "/usr/local/painelstream/func/main.sh"

validar_usuario_listeners "$USERNAME" "$PASS" "$LISTENERS"

sudo usermod -U "$USERNAME"
sudo usermod -s /bin/bash "$USERNAME"

sudo "$PAINELSTREAM/bin/ps-mount-add" "$USERNAME" "$PASS" "$LISTENERS"
sudo "$PAINELSTREAM/src/icecast-build.sh" || true

echo "{\"status\":\"success\",\"message\":\"Radio reativada com sucesso\",\"user\":\"$USERNAME\"}"
exit 0