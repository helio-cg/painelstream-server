#!/bin/bash

USERNAME=$1
PASS=$2
HIDE=2
LISTENERS=$3

# Includes
source "/usr/local/painelstream/func/main.sh"

validar_usuario_listeners "$USERNAME" "$PASS" "$LISTENERS"

export USERNAME PASS LISTENERS

TEMPLATE_PATH="/usr/local/painelstream/templates/mount.tpl"
DESTINO="/home/$USERNAME/config/mount.xml"

envsubst < "$TEMPLATE_PATH" > "$DESTINO"
chmod 660 "$DESTINO"

exit 0