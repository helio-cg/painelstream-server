#!/bin/bash
# example: add-user user P4$$w@rD 10

set -e

#----------------------------------------------------------#
#                Variáveis & Funções                       #
#----------------------------------------------------------#

USERNAME="$1"
PASS="$2"
HIDE=2
QUOTA_GB="$3"
LISTENERS="$4"

USER_CREATED=false

rollback() {
    echo "Erro detectado. Executando rollback..." >&2

    if [ "$USER_CREATED" = true ]; then
        sudo userdel -r "$USERNAME" 2>/dev/null || true
    fi

    echo "{\"status\":\"error\",\"message\":\"Falha na criacao da radio. Rollback executado.\"}"
    exit 1
}

trap rollback ERR

#----------------------------------------------------------#
#                Includes                                  #
#----------------------------------------------------------#
source "/usr/local/painelstream/func/main.sh"
HOMEDIR="$BASE/$USERNAME"

#----------------------------------------------------------#
#                Includes                                  #
#----------------------------------------------------------#
[ -z "$USERNAME" ] && echo "usuario obrigatorio" && exit 1
[ -z "$PASS" ] && echo "senha obrigatoria" && exit 1
[ -z "$QUOTA_GB" ] && QUOTA_GB="$DEFAULT_QUOTA_GB"
[ -z "$LISTENERS" ] && LISTENERS="$DEFAULT_LISTENERS"

[[ ! "$USERNAME" =~ ^[a-z]+$ ]] && echo "Usuario invalido, use apenas letras" && exit 1
id "$USERNAME" &>/dev/null && echo "usuario existe" && exit 1

if ! getent group "$GROUP" >/dev/null; then
    sudo groupadd "$GROUP"
fi

#----------------------------------------------------------#
#                Includes                                  #
#----------------------------------------------------------#
sudo /usr/sbin/useradd -m -d "$HOMEDIR" -s /bin/bash -g "$GROUP" "$USERNAME"
USER_CREATED=true

echo "$USERNAME:$PASS" | sudo chpasswd

#----------------------------------------------------------#
#               Estrutura de diretórios                    #
#----------------------------------------------------------#
sudo mkdir -p \
    "$HOMEDIR/autodj/Comercial" \
    "$HOMEDIR/autodj/Vinhetas" \
    "$HOMEDIR/config" \
    "$HOMEDIR/logs" \
    "$HOMEDIR/playlists" \
    "$HOMEDIR/stats"

sudo chown root:root "$HOMEDIR"
sudo chmod 755 "$HOMEDIR"

sudo chown -R "$USERNAME:$GROUP" "$HOMEDIR/autodj"
sudo chmod -R 775 "$HOMEDIR/autodj"

sudo chown -R root:root \
    "$HOMEDIR/config" \
    "$HOMEDIR/logs" \
    "$HOMEDIR/playlists" \
    "$HOMEDIR/stats"

sudo chmod -R 755 \
    "$HOMEDIR/config" \
    "$HOMEDIR/logs" \
    "$HOMEDIR/playlists" \
    "$HOMEDIR/stats"

#----------------------------------------------------------#
#                Icecast                                   #
#----------------------------------------------------------#
sudo "$PAINELSTREAM/bin/ps-mount-add" "$USERNAME" "$PASS" "$LISTENERS"
sudo "$PAINELSTREAM/src/icecast-build.sh"

#----------------------------------------------------------#
#                Quota                                     #
#----------------------------------------------------------#
if ! [[ "$QUOTA_GB" =~ ^[0-9]+$ ]]; then
    echo "Quota invalida, usando padrao ($DEFAULT_QUOTA_GB GB)"
    QUOTA_GB="$DEFAULT_QUOTA_GB"
fi

KB=$((QUOTA_GB * 1024 * 1024))
sudo setquota -u "$USERNAME" "$KB" "$KB" 0 0 "$FS_MOUNT"

#----------------------------------------------------------#
#                        Response                          #
#----------------------------------------------------------#
trap - ERR

echo "{\"status\":\"success\",\"message\":\"Radio criada com sucesso\",\"user\":\"$USERNAME\"}"
exit 0