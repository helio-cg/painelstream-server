#!/usr/bin/env bash
# exemplo: ps-user-add helihdjsh P4ssw0rd 5 50
#set -euo pipefail

# --------------------------
# Variáveis
# --------------------------
USERNAME="${1:-}"
PASSWORD="${2:-}"
QUOTA_GB="${3:-}"
LISTENERS="${4:-}"
HIDE=2
USER_CREATED=false
HOMEDIR="/home/$USERNAME"
BYTES=$((QUOTA_GB * 1024 * 1024 * 1024))

# --------------------------
# Includes e paths
# --------------------------
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$DIR/../func/main.sh"
source "$DIR/../func/libs/logger.sh"

# ---------------------------
# Validação
# ---------------------------
is_user_free
is_password_valid
validate_quota
validate_listeners

# --------------------------
# Estrutura de diretórios
# --------------------------

mkdir -p /home/$USERNAME
sudo mkdir -p \
    "$HOMEDIR/configs" \
    "$HOMEDIR/logs" \
    "$HOMEDIR/playlists" \
    "$HOMEDIR/stats" \
    "$HOMEDIR/midia/Comercial" \
    "$HOMEDIR/midia/Vinhetas" \

sudo chown root:root "$HOMEDIR"
sudo chmod 755 "$HOMEDIR"
sudo chown -R root:root "$HOMEDIR/configs" "$HOMEDIR/logs" "$HOMEDIR/playlists" "$HOMEDIR/stats"
sudo chmod -R 755 "$HOMEDIR/configs" "$HOMEDIR/logs" "$HOMEDIR/playlists" "$HOMEDIR/stats"
sudo chown -R sftpgo:sftpgo "$HOMEDIR/midia"
sudo chmod -R 770 "$HOMEDIR/midia"

# --------------------------
# Exporta variáveis para template Mount
# --------------------------
export USERNAME PASSWORD LISTENERS

TEMPLATE_PATH="$PAINELSTREAM/src/templates/mount.tpl"
DESTINO="$HOMEDIR/configs/mount.xml"

# --------------------------
# Gera mount.xml
# --------------------------
envsubst < "$TEMPLATE_PATH" > "$DESTINO" || erro "falha ao gerar mount.xml"
chmod 660 "$DESTINO" || erro "falha ao definir permissao do mount.xml"

# --------------------------
# Reload icecast.xml
# --------------------------
sudo "$PAINELSTREAM/src/icecast-build.sh" || erro "Falha ao buildar Icecast"

# --------------------------
# Logs
# --------------------------
log_action 'Criar usuário' "$USERNAME"

# --------------------------
# Resposta de sucesso
# --------------------------
sucesso "Radio criada com sucesso" "{\"user\":\"$USERNAME\"}"