#!/usr/bin/env bash
# exemplo: ps-user-add helihdjsh P4ssw0rd 5 50
set -euo pipefail

# --------------------------
# Variáveis
# --------------------------
USERNAME="${1:-}"
PASS="${2:-}"
QUOTA_GB="${3:-}"
LISTENERS="${4:-}"
HIDE=2
USER_CREATED=false
HOMEDIR="/home/$USERNAME"

# --------------------------
# Includes e paths
# --------------------------
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$DIR/../func/main.sh"
source "$DIR/../func/libs/logger.sh"

# ---------------------------
# Validação
# ---------------------------
is_user_free "$USERNAME" || exit 1
is_password_valid "$PASS" || exit 1
validate_quota "$QUOTA_GB" || exit 1
validate_listeners "$LISTENERS" || exit 1

# --------------------------
# Rollback só para criação do usuário
# --------------------------
rollback() {
    echo "Erro detectado durante criacao do usuario..." >&2
    if [ "$USER_CREATED" = true ]; then
        sudo userdel -r "$USERNAME" 2>/dev/null || true
    fi
    echo "{\"status\":\"error\",\"message\":\"Falha na criacao da radio. Rollback executado.\"}"
    exit 1
}

# --------------------------
# Criação do grupo e usuário
# --------------------------
trap rollback ERR

if ! getent group "$GROUP" >/dev/null; then
    sudo groupadd "$GROUP"
fi

sudo /usr/sbin/useradd -m -d "$HOMEDIR" -s "$DEFAULT_SHELL" -g "$GROUP" "$USERNAME"
USER_CREATED=true
echo "$USERNAME:$PASS" | sudo chpasswd

trap - ERR  # desativa rollback global após criação do usuário

# --------------------------
# Estrutura de diretórios
# --------------------------
sudo mkdir -p \
    "$HOMEDIR/autodj/Comercial" \
    "$HOMEDIR/autodj/Vinhetas" \
    "$HOMEDIR/config" \
    "$HOMEDIR/logs" \
    "$HOMEDIR/playlists" \
    "$HOMEDIR/stats"

sudo chown root:root "$HOMEDIR"
sudo chmod 755 "$HOMEDIR"
sudo chown -R "$USERNAME:$GROUP" "$HOMEDIR/autodj"
sudo chmod -R 775 "$HOMEDIR/autodj"
sudo chown -R root:root "$HOMEDIR/config" "$HOMEDIR/logs" "$HOMEDIR/playlists" "$HOMEDIR/stats"
sudo chmod -R 755 "$HOMEDIR/config" "$HOMEDIR/logs" "$HOMEDIR/playlists" "$HOMEDIR/stats"

# --------------------------
# Exporta variáveis para template Mount
# --------------------------
export USERNAME PASS LISTENERS

TEMPLATE_PATH="$PAINELSTREAM/templates/mount.tpl"
DESTINO="$HOMEDIR/config/mount.xml"

# --------------------------
# Gera mount.xml
# --------------------------
envsubst < "$TEMPLATE_PATH" > "$DESTINO" || erro "falha ao gerar mount.xml"
chmod 660 "$DESTINO" || erro "falha ao definir permissao do mount.xml"

# --------------------------
# Reload icecast.xml
# --------------------------
sudo "$PAINELSTREAM/src/icecast-build.sh" || erro "Falha ao buildar Icecast"

# --------------------------
# Define quota
# --------------------------
KB=$((QUOTA_GB * 1024 * 1024))
sudo setquota -u "$USERNAME" "$KB" "$KB" 0 0 "$FS_MOUNT" || erro "Falha ao definir quota"

# --------------------------
# Logs
# --------------------------
log_action 'Criar usuário' "$USERNAME"

# --------------------------
# Resposta de sucesso
# --------------------------
sucesso "Radio criada com sucesso" "{\"user\":\"$USERNAME\"}"