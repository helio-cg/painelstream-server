#!/bin/bash
# example: add-user user P4$$w@rD

#----------------------------------------------------------#
#                Variáveis & Funções                       #
#----------------------------------------------------------#

USER="$1"
PASS="$2" HIDE=2
QUOTA_GB="$3"

# Includes
source "/usr/local/painelstream/func/main.sh"
HOMEDIR="$BASE/$USER"

[ -z "$USER" ] && echo "usuario obrigatorio" && exit 1
[ -z "$PASS" ] && echo "senha obrigatoria" && exit 1
[ -z "$QUOTA_GB" ] && QUOTA_GB="$DEFAULT_QUOTA_GB"

[[ ! "$USER" =~ ^[a-z]+$ ]] && echo "Usuario invalido, use apenas letras" && exit 1
id "$USER" &>/dev/null && echo "usuario existe" && exit 1

useradd -m -d "$HOMEDIR" -s "$SHELL" -g "$GROUP" "$USER"
echo "$USER:$PASS" | chpasswd

#----------------------------------------------------------#
#               Estrutura de diretórios                    #
#----------------------------------------------------------#
mkdir -p \
    "$HOMEDIR/autodj/Comercial" \
    "$HOMEDIR/autodj/Vinhetas" \
    "$HOMEDIR/config" \
    "$HOMEDIR/logs" \
    "$HOMEDIR/playlists" \
    "$HOMEDIR/stats"

# Pasta principal precisa ser root para chroot
chown root:root "$HOMEDIR"
chmod 755 "$HOMEDIR"

# Só autodj pertence ao cliente
chown -R "$USER:$GROUP" "$HOMEDIR/autodj"
chmod -R 775 "$HOMEDIR/autodj"

# Restante fica root
chown -R root:root \
    "$HOMEDIR/config" \
    "$HOMEDIR/logs" \
    "$HOMEDIR/playlists" \
    "$HOMEDIR/stats"

chmod -R 755 \
    "$HOMEDIR/config" \
    "$HOMEDIR/logs" \
    "$HOMEDIR/playlists" \
    "$HOMEDIR/stats"

# Cria mount
sudo $PAINELSTREAM/bin/mount-create $USER $PASS 10

# Recarreca Icecast
sudo $PAINELSTREAM/src/icecast-build.sh

# Cria limite de espaçõ
KB=$((QUOTA_GB * 1024 * 1024))
setquota -u "$USER" "$KB" "$KB" 0 0 "$FS_MOUNT"

echo "radio criada"