#!/bin/bash

set -euo pipefail

# =============================
# CONFIG
# =============================
ALIAS="local"
TODAY=$(date +%F)

# =============================
# DEPENDÊNCIAS
# =============================
command -v mc >/dev/null || { echo "mc não instalado"; exit 1; }
command -v jq >/dev/null || { echo "jq não instalado"; exit 1; }
command -v bc >/dev/null || { echo "bc não instalado"; exit 1; }

# =============================
# LISTAR BUCKETS
# =============================
BUCKETS=$(mc ls "$ALIAS" | awk '{print $5}')

[ -z "$BUCKETS" ] && exit 0

# =============================
# LOOP
# =============================
for BUCKET in $BUCKETS; do

  USERNAME="$BUCKET"
  BASE_DIR="/home/$USERNAME/logs/storage-usage"
  FILE="$BASE_DIR/usage.csv"

  mkdir -p "$BASE_DIR"

  # =============================
  # TAMANHO
  # =============================
  SIZE_BYTES=$(mc du --json "$ALIAS/$BUCKET" 2>/dev/null | jq -r '.size // 0')

  if ! [[ "$SIZE_BYTES" =~ ^[0-9]+$ ]]; then
    echo "⚠️ erro: $BUCKET"
    continue
  fi

  SIZE_GB=$(echo "scale=4; $SIZE_BYTES/1024/1024/1024" | bc)

  # =============================
  # CRIAR CSV SE NÃO EXISTIR
  # =============================
  if [ ! -f "$FILE" ]; then
    echo "date,size_bytes,size_gb,avg_gb" > "$FILE"
  fi

  # =============================
  # EVITAR DUPLICAR DIA
  # =============================
  if grep -q "^$TODAY," "$FILE"; then
    echo "⏭️ [$BUCKET] já registrado hoje"
    continue
  fi

  # =============================
  # CALCULAR MÉDIA ANTES DE INSERIR
  # =============================
  TOTAL_GB=$(awk -F',' 'NR>1 {sum+=$3} END {print sum}' "$FILE")
  COUNT=$(awk -F',' 'NR>1 {count++} END {print count}' "$FILE")

  if [ -z "$COUNT" ] || [ "$COUNT" -eq 0 ]; then
    AVG_GB="$SIZE_GB"
  else
    NEW_TOTAL=$(echo "$TOTAL_GB + $SIZE_GB" | bc)
    NEW_COUNT=$((COUNT + 1))
    AVG_GB=$(echo "scale=4; $NEW_TOTAL / $NEW_COUNT" | bc)
  fi

  # =============================
  # INSERIR LINHA
  # =============================
  echo "$TODAY,$SIZE_BYTES,$SIZE_GB,$AVG_GB" >> "$FILE"

  echo "✔ [$BUCKET] $SIZE_GB GB | média: $AVG_GB GB"

done

echo "✅ Finalizado"