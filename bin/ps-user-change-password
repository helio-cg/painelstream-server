#!/bin/bash
set -e

USERNAME="${1:-}"
PASSWORD="${2:-}"

# --------------------------
# Includes e paths
# --------------------------
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$DIR/../func/main.sh"
source "$DIR/../func/libs/logger.sh"

# ---------------------------
# Validação
# ---------------------------
is_user_valid
is_password_valid

# --------------------------
# Altera Senha
# --------------------------
echo "$USERNAME:$PASSWORD" | sudo chpasswd

sucesso "Senha alterada com sucesso" "{\"user\":\"$USERNAME\"}"