#!/bin/bash
set -e

USERNAME="$1"
NEWPASS="$2"

# Includes
source "/usr/local/painelstream/func/main.sh"

[ -z "$USERNAME" ] && echo '{"status":"error","message":"usuario obrigatorio"}' && exit 1
[ -z "$NEWPASS" ] && echo '{"status":"error","message":"nova senha obrigatoria"}' && exit 1
[[ ! "$USERNAME" =~ ^[a-z]+$ ]] && echo '{"status":"error","message":"usuario invalido"}' && exit 1

if ! id "$USERNAME" &>/dev/null; then
    echo '{"status":"error","message":"usuario nao existe"}'
    exit 1
fi

echo "$USERNAME:$NEWPASS" | sudo chpasswd

echo "{\"status\":\"success\",\"message\":\"Senha alterada com sucesso\",\"user\":\"$USERNAME\"}"
exit 0