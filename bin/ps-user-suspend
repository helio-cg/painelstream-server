#!/bin/bash
set -e

USERNAME="$1"

# Includes
source "/usr/local/painelstream/func/main.sh"

[[ -z "$USERNAME" ]] && erro "usuario obrigatorio"
[[ ! "$USERNAME" =~ ^[a-z]{6,10}$ ]] && erro "usuario invalido"
! id "$USERNAME" &>/dev/null && erro "usuario nao existe"

pkill -u "$USERNAME" 2>/dev/null

sudo rm -rf /home/$USERNAME/config/mount.xml
sudo "$PAINELSTREAM/src/icecast-build.sh" || true

sudo usermod -L "$USERNAME"
sudo usermod -s /usr/sbin/nologin "$USERNAME"

echo "{\"status\":\"success\",\"message\":\"Radio suspensa com sucesso\",\"user\":\"$USERNAME\"}"
exit 0