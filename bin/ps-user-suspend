#!/bin/bash
set -e

USERNAME="$1"

[ -z "$USERNAME" ] && echo '{"status":"error","message":"usuario obrigatorio"}' && exit 1
[[ ! "$USERNAME" =~ ^[a-z]+$ ]] && echo '{"status":"error","message":"usuario invalido"}' && exit 1

if ! id "$USERNAME" &>/dev/null; then
    echo '{"status":"error","message":"usuario nao existe"}'
    exit 1
fi

pkill -u "$USERNAME" 2>/dev/null

sudo rm -rf /home/$USER/config/mount.xml
sudo "$PAINELSTREAM/src/icecast-build.sh" || true

sudo usermod -L "$USERNAME"
sudo usermod -s /usr/sbin/nologin "$USERNAME"

echo "{\"status\":\"success\",\"message\":\"Radio suspensa com sucesso\",\"user\":\"$USERNAME\"}"
exit 0