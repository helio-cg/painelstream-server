#!/usr/bin/env bash
# exemplo: ps-user-suspend USERNAME

set -euo pipefail

# --------------------------
# Variáveis
# --------------------------
USERNAME="${1:-}"

# --------------------------
# Includes e paths
# --------------------------
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$DIR/../func/main.sh"
source "$DIR/../func/libs/logger.sh"

# ---------------------------
# Validação
# ---------------------------
is_user_valid

# --------------------------
# Includes e paths
# --------------------------
#PAINELSTREAM="/usr/local/painelstream"

# --------------------------
# Mata processos do usuário
# --------------------------
pkill -u "$USERNAME" 2>/dev/null || true

# --------------------------
# Renomeia mount.xml e rebuild Icecast
# --------------------------
MOUNT_XML="/home/$USERNAME/configs/mount.xml"
SUSPEND_XML="/home/$USERNAME/configs/suspend.xml"

if [[ -f "$MOUNT_XML" ]]; then
    sudo mv "$MOUNT_XML" "$SUSPEND_XML" || erro "falha ao renomear mount.xml"
else
    erro "usuario já está suspenso ou mount.xml não existe"
fi

sudo "$PAINELSTREAM/src/icecast-build.sh" || true

# --------------------------
# Bloqueia usuário
# --------------------------
sudo usermod -L "$USERNAME"
sudo usermod -s /usr/sbin/nologin "$USERNAME"

# --------------------------
# Resposta de sucesso
# --------------------------
sucesso "Radio suspensa com sucesso" "{\"user\":\"$USERNAME\"}"