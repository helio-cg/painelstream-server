#!/usr/bin/env bash
# exemplo: ps-user-delete USERNAME

set -euo pipefail

# --------------------------
# Variáveis
# --------------------------
USERNAME="${1:-}"

# --------------------------
# Includes e paths
# --------------------------
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$DIR/../func/main.sh"
source "$DIR/../func/libs/logger.sh"

# ---------------------------
# Validação
# ---------------------------
is_user_valid


# --------------------------
# Includes e paths
# --------------------------
#PAINELSTREAM="/usr/local/painelstream"

# --------------------------
# Mata processos do usuário
# --------------------------
pkill -u "$USERNAME" 2>/dev/null || true

# --------------------------
# Remove usuário e diretórios
# --------------------------
# Remove o usuário do sistema
sudo userdel "$USERNAME" || erro "falha ao remover usuario"

# Remove manualmente o home se existir
[[ -d "/home/$USERNAME" ]] && sudo rm -rf "/home/$USERNAME"

# --------------------------
# Rebuild Icecast
# --------------------------
sudo "$PAINELSTREAM/src/icecast-build.sh" || true

# --------------------------
# Resposta de sucesso
# --------------------------
sucesso "Radio removida com sucesso"