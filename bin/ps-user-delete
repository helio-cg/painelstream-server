#!/usr/bin/env bash
# exemplo: ps-user-delete USERNAME

set -euo pipefail

# --------------------------
# Variáveis
# --------------------------
USERNAME="${1:-}"

# --------------------------
# Includes e paths
# --------------------------
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$DIR/../func/main.sh"
source "$DIR/../func/libs/logger.sh"

# ---------------------------
# Validação
# ---------------------------
#is_user_valid


# --------------------------
# Includes e paths
# --------------------------
#PAINELSTREAM="/usr/local/painelstream"

# --------------------------
# Mata processos do usuário
# --------------------------
pkill -u "$USERNAME" 2>/dev/null || true

# --------------------------
# Remove usuário e diretórios
# --------------------------

# ===== VALIDAÇÃO =====
if [ -z "$USERNAME" ]; then
  echo "❌ Uso: $0 usuario"
  exit 1
fi

# ===== GERAR TOKEN =====
echo "🔐 Gerando token..."
TOKEN=$(curl --anyauth -s -u "${ADMIN_USER}:${ADMIN_PASSWORD}" \
  "${ENDPOINT}/api/v2/token" | jq -r .access_token)

if [ "$TOKEN" = "null" ] || [ -z "$TOKEN" ]; then
  echo "❌ Erro ao obter token"
  exit 1
fi

# ===== VERIFICAR SE USUÁRIO EXISTE =====
echo "🔍 Verificando usuário..."
HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
  -H "Authorization: Bearer ${TOKEN}" \
  "${ENDPOINT}/api/v2/users/${USERNAME}")

if [ "$HTTP_CODE" != "200" ]; then
  echo "❌ Usuário não encontrado (${USERNAME})"
  exit 1
fi

# ===== DELETAR USUÁRIO =====
echo "🗑️ Removendo usuário no SFTPGo..."
HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" -X DELETE \
  "${ENDPOINT}/api/v2/users/${USERNAME}" \
  -H "Authorization: Bearer ${TOKEN}")

if [[ ! "$HTTP_CODE" =~ ^2 ]]; then
  echo "❌ Erro ao remover usuário (HTTP $HTTP_CODE)"
  erro "falha ao remover usuário do SFTPGo"
fi

echo "✅ Usuário removido do SFTPGo"

# ===== REMOVER ARQUIVOS =====
USER_DIR="/home/${USERNAME}"
echo "🧹 Removendo arquivos em $USER_DIR..."
[[ -d "$USER_DIR" ]] && sudo rm -rf "$USER_DIR"
echo "✅ Pasta removida"

# --------------------------
# Rebuild Icecast
# --------------------------
sudo "$PAINELSTREAM/src/icecast-build.sh" || true

# --------------------------
# Resposta de sucesso
# --------------------------
sucesso "Radio removida com sucesso"